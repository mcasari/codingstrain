        <mxCell id="legend-title" value="Legend &amp;amp; Compiler Rules" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=16;fontStyle=1;fontColor=#37474F;" vertex="1" parent="1">
          <mxGeometry x="120" y="470" width="960" height="28" as="geometry"/>
        </mxCell>

        <!-- Legend: sealed -->
        <mxCell id="leg-sealed" value="&lt;b&gt;sealed class&lt;/b&gt;&lt;br&gt;• Must use permits&lt;br&gt;• Restricts inheritance" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#E3F2FD;strokeColor=#1E88E5;strokeWidth=2;fontColor=#0D47A1;fontSize=12;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="510" width="300" height="88" as="geometry"/>
        </mxCell>

        <!-- Legend: final -->
        <mxCell id="leg-final" value="&lt;b&gt;final class&lt;/b&gt;&lt;br&gt;• No further inheritance&lt;br&gt;• Leaf node" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;fontColor=#1B5E20;fontSize=12;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="420" y="510" width="300" height="88" as="geometry"/>
        </mxCell>

        <!-- Legend: non-sealed -->
        <mxCell id="leg-nonsealed" value="&lt;b&gt;non-sealed class&lt;/b&gt;&lt;br&gt;• Reverts to open inheritance&lt;br&gt;• Escape hatch" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFF3E0;strokeColor=#EF6C00;strokeWidth=2;fontColor=#E65100;fontSize=12;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="760" y="510" width="340" height="88" as="geometry"/>
        </mxCell>

        <!-- Compiler verification box -->
        <mxCell id="verify-box" value="&lt;b&gt;COMPILER VERIFICATION:&lt;/b&gt; Every permitted subclass MUST be final, sealed, or non-sealed&lt;br&gt;&lt;br&gt;• Circle → final ✓   • Rectangle → sealed ✓   • FancyRectangle → non-sealed ✓&lt;br&gt;• Square / Oblong → final ✓   • RoundedRectangle → extends non-sealed parent (not in permits) ✓&lt;br&gt;&lt;br&gt;&lt;b&gt;Missing modifier on a permitted type → compile error. Undeclared subclass → compile error.&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;dashed=1;dashPattern=10 6;fontColor=#B71C1C;fontSize=12;align=center;verticalAlign=middle;spacingTop=8;spacingBottom=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="620" width="1080" height="130" as="geometry"/>
        </mxCell>

        <!-- Pattern matching payoff -->
        <mxCell id="switch-box" value="&lt;b&gt;Why it matters:&lt;/b&gt; A closed hierarchy lets the compiler prove exhaustiveness in &lt;code&gt;switch&lt;/code&gt; / pattern matching — no surprise subtypes outside &lt;code&gt;permits&lt;/code&gt; (until a &lt;code&gt;non-sealed&lt;/code&gt; branch re-opens inheritance)." style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#E8EAF6;strokeColor=#3949AB;strokeWidth=2;fontColor=#1A237E;fontSize=12;align=center;verticalAlign=middle;spacingTop=6;spacingBottom=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="770" width="1080" height="56" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
