        <mxCell id="body" value="Fail fast at startup with validated config:&amp;#xa;&amp;#xa;@Validated + @ConfigurationProperties&amp;#xa;&amp;#xa;Bad YAML? App won't start. That's a feature." style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontColor=#e7e9ea;fontSize=13;spacingLeft=20;spacingTop=12;whiteSpace=wrap;" vertex="1" parent="1">
