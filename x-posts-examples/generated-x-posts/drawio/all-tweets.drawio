        </mxCell>
        <mxCell id="code-bg" value="" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#192734;strokeColor=#38444d;strokeWidth=1;" vertex="1" parent="1">
          <mxGeometry x="36" y="202" width="488" height="132" as="geometry"/>
        </mxCell>
        <mxCell id="code" value="@RestController&amp;#xa;@RequestMapping(&quot;/library&quot;)&amp;#xa;public class BookController {&amp;#xa;  @GetMapping(&quot;/book&quot;)&amp;#xa;  public List&lt;Book&gt; findAll() { ... }&amp;#xa;}" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontColor=#89cff0;fontSize=11;fontFamily=Courier New;spacingLeft=12;spacingTop=8;whiteSpace=wrap;" vertex="1" parent="1">
