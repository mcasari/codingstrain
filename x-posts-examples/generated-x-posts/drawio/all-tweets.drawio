        </mxCell>
        <mxCell id="code" value="@GetMapping&amp;#xa;public PagedResponse&lt;User&gt; getUsers(Pageable pageable) {&amp;#xa;  Page&lt;User&gt; page = repository.findAll(pageable);&amp;#xa;  return new PagedResponse&lt;&gt;(page.getContent(), ...);&amp;#xa;}" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontColor=#89cff0;fontSize=11;fontFamily=Courier New;spacingLeft=12;spacingTop=8;whiteSpace=wrap;" vertex="1" parent="1">
