          <mxGeometry x="36" y="182" width="488" height="132" as="geometry"/>
        </mxCell>
        <mxCell id="code" value="@Validated&amp;#xa;@ConfigurationProperties(prefix = &quot;app&quot;)&amp;#xa;public class AppProperties {&amp;#xa;  @NotBlank private String name;&amp;#xa;  @Min(1) @Max(60) private Integer timeout;&amp;#xa;}" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=top;fontColor=#89cff0;fontSize=11;fontFamily=Courier New;spacingLeft=12;spacingTop=8;whiteSpace=wrap;" vertex="1" parent="1">
