  <diagram id="sealed-classes-hierarchy" name="Java 17 Sealed Classes">
    <mxGraphModel dx="1400" dy="900" grid="1" gridSize="10" guides="1" tooltips="1" connect="1" arrows="1" fold="1" page="1" pageScale="1" pageWidth="1200" pageHeight="920" math="0" shadow="0" background="#FFFFFF">
      <root>
        <mxCell id="0"/>
        <mxCell id="1" parent="0"/>

        <!-- Title -->
        <mxCell id="title" value="Java 17 Sealed Classes: Closed Hierarchy Verification" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=22;fontStyle=1;fontColor=#1565C0;fontFamily=Helvetica;" vertex="1" parent="1">
          <mxGeometry x="120" y="24" width="960" height="40" as="geometry"/>
        </mxCell>

        <!-- permits tag -->
        <mxCell id="permits-tag" value="permits" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#7E57C2;fontColor=#4527A0;fontSize=11;fontStyle=1;arcSize=50;" vertex="1" parent="1">
          <mxGeometry x="520" y="78" width="56" height="22" as="geometry"/>
        </mxCell>

        <!-- Root: Shape (sealed) -->
        <mxCell id="shape" value="abstract sealed class Shape&#xa;permits Circle, Rectangle, FancyRectangle" style="rounded=1;whiteSpace=wrap;html=1;arcSize=14;fillColor=#E3F2FD;strokeColor=#1E88E5;strokeWidth=2;fontColor=#0D47A1;fontSize=12;fontStyle=0;fontFamily=Courier New;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="380" y="100" width="340" height="64" as="geometry"/>
        </mxCell>

        <!-- Level 1: Circle (final) -->
        <mxCell id="circle" value="final class Circle extends Shape" style="rounded=1;whiteSpace=wrap;html=1;arcSize=14;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;fontColor=#1B5E20;fontSize=12;fontFamily=Courier New;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="80" y="240" width="260" height="52" as="geometry"/>
        </mxCell>

        <!-- Level 1: Rectangle (sealed) -->
        <mxCell id="rectangle" value="sealed class Rectangle extends Shape&#xa;permits Square, Oblong" style="rounded=1;whiteSpace=wrap;html=1;arcSize=14;fillColor=#E3F2FD;strokeColor=#1E88E5;strokeWidth=2;fontColor=#0D47A1;fontSize=12;fontFamily=Courier New;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="400" y="228" width="320" height="64" as="geometry"/>
        </mxCell>

        <mxCell id="permits-rect-tag" value="permits" style="rounded=1;whiteSpace=wrap;html=1;fillColor=#EDE7F6;strokeColor=#7E57C2;fontColor=#4527A0;fontSize=10;fontStyle=1;arcSize=50;" vertex="1" parent="1">
          <mxGeometry x="532" y="218" width="56" height="20" as="geometry"/>
        </mxCell>

        <!-- Level 1: FancyRectangle (non-sealed) -->
        <mxCell id="fancy" value="non-sealed class FancyRectangle extends Shape" style="rounded=1;whiteSpace=wrap;html=1;arcSize=14;fillColor=#FFF3E0;strokeColor=#EF6C00;strokeWidth=2;fontColor=#E65100;fontSize=12;fontFamily=Courier New;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="780" y="240" width="320" height="52" as="geometry"/>
        </mxCell>

        <!-- Level 2 under Rectangle: Square -->
        <mxCell id="square" value="final class Square extends Rectangle" style="rounded=1;whiteSpace=wrap;html=1;arcSize=14;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;fontColor=#1B5E20;fontSize=12;fontFamily=Courier New;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="320" y="380" width="260" height="52" as="geometry"/>
        </mxCell>

        <!-- Level 2 under Rectangle: Oblong -->
        <mxCell id="oblong" value="final class Oblong extends Rectangle" style="rounded=1;whiteSpace=wrap;html=1;arcSize=14;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;fontColor=#1B5E20;fontSize=12;fontFamily=Courier New;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="620" y="380" width="270" height="52" as="geometry"/>
        </mxCell>

        <!-- Level 2 under FancyRectangle: RoundedRectangle -->
        <mxCell id="rounded" value="class RoundedRectangle extends FancyRectangle" style="rounded=1;whiteSpace=wrap;html=1;arcSize=14;fillColor=#FFF3E0;strokeColor=#EF6C00;strokeWidth=2;fontColor=#E65100;fontSize=12;fontFamily=Courier New;align=center;verticalAlign=middle;shadow=1;" vertex="1" parent="1">
          <mxGeometry x="800" y="380" width="320" height="52" as="geometry"/>
        </mxCell>

        <mxCell id="open-ext" value="open extension" style="text;html=1;strokeColor=none;fillColor=none;align=left;verticalAlign=middle;fontSize=11;fontStyle=2;fontColor=#EF6C00;" vertex="1" parent="1">
          <mxGeometry x="1130" y="395" width="100" height="24" as="geometry"/>
        </mxCell>

        <!-- Edges: Shape -> children -->
        <mxCell id="e-shape-circle" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#37474F;strokeWidth=2;" edge="1" parent="1" source="shape" target="circle">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-shape-rect" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#37474F;strokeWidth=2;" edge="1" parent="1" source="shape" target="rectangle">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-shape-fancy" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#37474F;strokeWidth=2;" edge="1" parent="1" source="shape" target="fancy">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Edges: Rectangle -> Square, Oblong -->
        <mxCell id="e-rect-square" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#37474F;strokeWidth=2;" edge="1" parent="1" source="rectangle" target="square">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>
        <mxCell id="e-rect-oblong" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#37474F;strokeWidth=2;" edge="1" parent="1" source="rectangle" target="oblong">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Dashed edge: FancyRectangle -> RoundedRectangle -->
        <mxCell id="e-fancy-rounded" style="edgeStyle=orthogonalEdgeStyle;rounded=0;orthogonalLoop=1;jettySize=auto;html=1;endArrow=block;endFill=1;strokeColor=#EF6C00;strokeWidth=2;dashed=1;dashPattern=8 6;" edge="1" parent="1" source="fancy" target="rounded">
          <mxGeometry relative="1" as="geometry"/>
        </mxCell>

        <!-- Legend title -->
        <mxCell id="legend-title" value="Legend &amp;amp; Compiler Rules" style="text;html=1;strokeColor=none;fillColor=none;align=center;verticalAlign=middle;fontSize=16;fontStyle=1;fontColor=#37474F;" vertex="1" parent="1">
          <mxGeometry x="120" y="470" width="960" height="28" as="geometry"/>
        </mxCell>

        <!-- Legend: sealed -->
        <mxCell id="leg-sealed" value="&lt;b&gt;sealed class&lt;/b&gt;&lt;br&gt;• Must use permits&lt;br&gt;• Restricts inheritance" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#E3F2FD;strokeColor=#1E88E5;strokeWidth=2;fontColor=#0D47A1;fontSize=12;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="80" y="510" width="300" height="88" as="geometry"/>
        </mxCell>

        <!-- Legend: final -->
        <mxCell id="leg-final" value="&lt;b&gt;final class&lt;/b&gt;&lt;br&gt;• No further inheritance&lt;br&gt;• Leaf node" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#E8F5E9;strokeColor=#2E7D32;strokeWidth=2;fontColor=#1B5E20;fontSize=12;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="420" y="510" width="300" height="88" as="geometry"/>
        </mxCell>

        <!-- Legend: non-sealed -->
        <mxCell id="leg-nonsealed" value="&lt;b&gt;non-sealed class&lt;/b&gt;&lt;br&gt;• Reverts to open inheritance&lt;br&gt;• Escape hatch" style="rounded=1;whiteSpace=wrap;html=1;arcSize=10;fillColor=#FFF3E0;strokeColor=#EF6C00;strokeWidth=2;fontColor=#E65100;fontSize=12;align=left;verticalAlign=top;spacingLeft=12;spacingTop=10;" vertex="1" parent="1">
          <mxGeometry x="760" y="510" width="340" height="88" as="geometry"/>
        </mxCell>

        <!-- Compiler verification box -->
        <mxCell id="verify-box" value="&lt;b&gt;COMPILER VERIFICATION:&lt;/b&gt; Every permitted subclass MUST be final, sealed, or non-sealed&lt;br&gt;&lt;br&gt;• Circle → final ✓   • Rectangle → sealed ✓   • FancyRectangle → non-sealed ✓&lt;br&gt;• Square / Oblong → final ✓   • RoundedRectangle → extends non-sealed parent (not in permits) ✓&lt;br&gt;&lt;br&gt;&lt;b&gt;Missing modifier on a permitted type → compile error. Undeclared subclass → compile error.&lt;/b&gt;" style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#FFEBEE;strokeColor=#C62828;strokeWidth=2;dashed=1;dashPattern=10 6;fontColor=#B71C1C;fontSize=12;align=center;verticalAlign=middle;spacingTop=8;spacingBottom=8;" vertex="1" parent="1">
          <mxGeometry x="60" y="620" width="1080" height="130" as="geometry"/>
        </mxCell>

        <!-- Pattern matching payoff -->
        <mxCell id="switch-box" value="&lt;b&gt;Why it matters:&lt;/b&gt; A closed hierarchy lets the compiler prove exhaustiveness in &lt;code&gt;switch&lt;/code&gt; / pattern matching — no surprise subtypes outside &lt;code&gt;permits&lt;/code&gt; (until a &lt;code&gt;non-sealed&lt;/code&gt; branch re-opens inheritance)." style="rounded=1;whiteSpace=wrap;html=1;arcSize=8;fillColor=#E8EAF6;strokeColor=#3949AB;strokeWidth=2;fontColor=#1A237E;fontSize=12;align=center;verticalAlign=middle;spacingTop=6;spacingBottom=6;" vertex="1" parent="1">
          <mxGeometry x="60" y="770" width="1080" height="56" as="geometry"/>
        </mxCell>

      </root>
    </mxGraphModel>
  </diagram>
